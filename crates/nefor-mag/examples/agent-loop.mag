;; The agentic loop — agent as a composition of primitives
;; This is what stdlib's (agent) would expand to
;;
;; The types form a clean cycle:
;;   generic-provider.ProviderOut -> (generic-tool.ToolCalls | generic-provider.FinalAnswer)
;;   generic-tool.ToolCalls -> ToolHandle -> generic-provider.ProviderOut (tool results become context)
;;   generic-provider.ProviderOut feeds back to llm call

(type generic-provider.ProviderOut)
(type generic-tool.ToolCalls)
(type ToolHandle)
(type generic-provider.FinalAnswer)
(type LoopExhausted)

(let [call     (node "llm" {:model "opus"
                            :system "You are a helpful coding assistant."
                            :tools ["fs/read" "fs/edit" "grep" "shell"]}
                 : generic-provider.ProviderOut -> (generic-tool.ToolCalls | generic-provider.FinalAnswer))

      dispatch (node "run-tool" {}
                 : generic-tool.ToolCalls -> ToolHandle)

      result   (node "tool-result" {}
                 : ToolHandle -> generic-provider.ProviderOut)

      bound    (node "loop-counter" {:max 50}
                 : generic-provider.ProviderOut -> (generic-provider.ProviderOut | LoopExhausted))

      exhaust  (node "llm" {:model "opus"
                            :system "Summarize what you accomplished so far."}
                 : LoopExhausted -> generic-provider.FinalAnswer)

      output   (node "sink" {}
                 : generic-provider.FinalAnswer -> generic-provider.FinalAnswer)]

  (graph
    call     -> dispatch
    call     -> output
    dispatch -> result
    result   -> bound
    bound    -> call
    bound    -> exhaust
    exhaust  -> output
    :terminal output))
